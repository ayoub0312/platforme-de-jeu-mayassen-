# Base de données locale (SQLite) — utilisée si TURSO_DATABASE_URL n'est pas défini.
DATABASE_URL="file:./dev.db"

# Turso (libSQL) — base de données distante pour la production.
# Laisser vide en développement local pour utiliser DATABASE_URL (SQLite).
# TURSO_DATABASE_URL="libsql://votre-base.aws-eu-west-1.turso.io"
# TURSO_AUTH_TOKEN=""

# Upstash Redis — rate limiting et gestion atomique du stock des lots.
# Sans ces variables, un stockage en mémoire locale est utilisé (non partagé
# entre plusieurs instances, à réserver au développement).
# UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# URL publique de base utilisée pour construire les liens dans les emails
# (ex: le lien du bon d'achat scanné via QR code). À adapter au domaine réel.
APP_BASE_URL="http://localhost:3000"

# Secret utilisé pour signer les sessions admin et chiffrer les mots de passe
# d'application (SMTP) stockés en base. Générez une chaîne aléatoire d'au
# moins 32 caractères pour la production (ex: openssl rand -hex 32).
SESSION_SECRET=""

# Secret partagé avec le site vitrine Obooking (widget d'intégration cross-domain).
SHARED_API_SECRET=""
