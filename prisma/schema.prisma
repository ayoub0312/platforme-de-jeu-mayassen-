generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Ligne globale (id: "main", partnerId: null) = réglages/branding par défaut du
// site. Un partenaire n'a de ligne dédiée que s'il a déjà personnalisé ses
// réglages (créée à la volée par updateSiteSettings) ; tant qu'il n'en a pas,
// il hérite en lecture de la ligne "main". Voir MIGRATION_PROD.md.
model SiteSettings {
  id                  String  @id @default(cuid())
  partnerId           String? @unique
  partner             Partner? @relation(fields: [partnerId], references: [id])
  heroVideoData       String? // base64, capped at ~4MB client + server side
  heroVideoMimeType   String?
  heroPosterData      String? // shown when no video is configured, or as <video poster>
  heroPosterMimeType  String?

  // Réglages globaux (page "Paramètres" du back-office)
  referralBonusSpins         Int     @default(2) // Lancers offerts au parrain par filleul inscrit
  defaultSenderEmail         String? // Utilisé si une campagne n'a pas sa propre adresse d'envoi
  defaultSenderEmailPassword String? // Mot de passe d'application, chiffré (AES-256-GCM)

  // Programme de fidélité « Points Merci » (Phase 1) — configurable par le
  // super admin. Voir PLAN_FIDELITE.md.
  loyaltyEnabled      Boolean @default(false) // Active/désactive le programme
  pointsPerTnd        Float   @default(1)      // GAIN : points gagnés par 1 TND dépensé
  redeemPointsPerTnd  Int     @default(100)    // CONVERSION : points requis pour 1 TND de bon
  minRedeemPoints     Int     @default(500)    // Seuil minimum de points pour convertir
  voucherValidityDays Int     @default(90)     // Durée de validité d'un bon (jours)
}

model PromoBanner {
  id            String   @id @default(cuid())
  imageData     String
  imageMimeType String
  linkUrl       String? // Optional — banner is purely visual if no destination is set
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  phone String?
  name  String?
  role  Role    @default(PLAYER)
  passwordHash String?
  normalizedEmail String? // Email normalisé pour détecter les alias (Gmail +tag, dots)

  // Rôle PARTNER uniquement : partenaire auquel ce compte est rattaché.
  // Remplace l'ancienne résolution par heuristique (domaine email) au login.
  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  //  partage
  referralCode String  @unique @default(cuid())
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  // Relations
  playTokens PlayToken[]
  wonPrizes  UserPrize[]
  leads      LeadCapture[]
  receiptSubmissions ReceiptSubmission[]
  // Lien optionnel vers un compte client final (espace client, auth séparée
  // de celle-ci) — un Customer qui joue à un jeu se voit relier au User
  // PLAYER existant/créé par le flux de jeu (même email), pour réutiliser
  // tel quel tout le système de campagnes/lots/participations.
  customer   Customer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPERADMIN
  PARTNER
  PLAYER
  READONLY
}

enum GameMode {
  ROULETTE
  DRAW
}

model Partner {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique // Identifiant URL-safe, généré à la création (ex: "obooking")
  isActive       Boolean       @default(true) // Un partenaire désactivé ne peut plus se connecter
  email          String? // Email de contact du partenaire (distinct des emails des comptes User liés)
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  allowedDomains String // Ex: "supermarche.com,boutique.fr"

  // Auto-inscription (formulaire public /partner/signup) : un partenaire créé
  // par le Super Admin (Phase 3) est directement APPROVED ; un partenaire
  // auto-inscrit démarre PENDING et ne peut pas se connecter tant qu'il n'est
  // pas validé (voir loginAdmin).
  status      PartnerStatus @default(PENDING)
  requestedAt DateTime      @default(now())
  reviewedAt  DateTime?

  campaigns      Campaign[]
  capturedLeads  LeadCapture[]
  users          User[]
  siteSettings   SiteSettings?
  customers      Customer[] // Clients finaux rattachés à ce partenaire (fidélité)
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
}

model Campaign {
  id        String        @id @default(cuid())
  partnerId String?
  partner   Partner?      @relation(fields: [partnerId], references: [id])
  title     String
  description String? // Résumé affiché dans le wizard admin et, à terme, sur la fiche campagne
  category    String? // Catégorie choisie explicitement dans le wizard (remplace l'heuristique côté client)
  startDate DateTime
  endDate   DateTime
  isActive  Boolean       @default(true)
  gameMode  GameMode      @default(ROULETTE)
  imageData     String? // Image de la campagne encodée en base64 (stockée en DB)
  imageMimeType String? // Ex: image/jpeg, image/png

  // Wizard admin (brouillon, QR unique par campagne, template d'origine)
  // isDraft défaut à false pour ne pas transformer les campagnes déjà publiées
  // en brouillons lors de la migration ; le wizard le passe explicitement à
  // true à la création puis à false à la publication (étape 5).
  isDraft       Boolean @default(false)
  qrCodeToken   String  @unique @default(cuid())
  templateUsed  String?
  spinsPerClient      Int     @default(1) // Nb de lancers/entrées offerts à la vérification OTP (flow QR direct)
  postSignupMessage   String? // Message affiché après inscription (mode Tirage)
  qrColor             String? @default("#F97316") // Couleur du QR téléchargeable
  allowMultipleWins   Boolean @default(true) // Tirage au sort : un participant peut-il gagner plusieurs lots de la meme campagne

  // Email d'envoi automatique au gagnant (identité de l'agence/partenaire)
  senderEmail         String?
  senderEmailPassword String? // Mot de passe d'application, chiffré (AES-256-GCM) avant stockage

  prizes    Prize[]
  leads     LeadCapture[]
  tokens    PlayToken[]
  receiptSubmissions ReceiptSubmission[]

  // Ads & Promos (Manageable from Dashboard)
  adBadge1   String?
  adTitle1   String?
  adDesc1    String?
  adBadge2   String?
  adTitle2   String?
  adDesc2    String?
  adBadge3   String?
  adTitle3   String?
  adDesc3    String?
  promoTitle String?
  promoCode  String?
  promoDesc  String?
  promoUrl   String?

  @@index([isActive, startDate, endDate])
}

model Prize {
  id              String      @id @default(cuid())
  campaignId      String
  campaign        Campaign    @relation(fields: [campaignId], references: [id])
  name            String
  type            PrizeType
  totalStock      Int // -1 pour illimité
  remainingStock  Int // Doit être synchronisé avec Redis
  winProbability  Float // Ex: 0.05
  fallbackPrizeId String? // ID du lot de consolation
  winners         UserPrize[]
  color           String? // Couleur du segment (config roulette)
  textColor       String? // Couleur du texte du segment (null = contraste auto)
  imageData       String? // Image du segment/lot encodée en base64
  imageMimeType   String?
  order           Int         @default(0) // Tri pour le drag & drop (même pattern que PromoBanner.order)

  drawDate DateTime? // Date du tirage au sort
  validityDays Int? @default(30) // Durée de validité en jours
}

enum PrizeType {
  PHYSICAL
  DIGITAL
}

model UserPrize {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prizeId   String
  prize     Prize    @relation(fields: [prizeId], references: [id])
  claimedAt DateTime @default(now())
  status    String   @default("PENDING") // PENDING, DELIVERED, CONTACTED, RETRIEVED
}

model PlayToken {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  campaignId String
  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  status     TokenStatus @default(UNUSED)
  earnedVia  EarnMethod
  createdAt  DateTime    @default(now())
}

enum TokenStatus {
  UNUSED
  USED
  EXPIRED
}

enum EarnMethod {
  SIGNUP
  REFERRAL
  RECEIPT_UPLOAD
  ADMIN_GRANT
  VISIT_WEBSITE
  FOLLOW_SOCIAL
  JOIN_DRAW
}

model LeadCapture {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id])
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  source     String // "WIDGET", "QR_CODE", "LINK"
  createdAt  DateTime @default(now())

  @@unique([userId, campaignId]) // Garantit un seul lead par utilisateur et par campagne
}

enum ReceiptStatus {
  PENDING
  APPROVED
  REJECTED
}

model ReceiptSubmission {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  campaignId      String
  campaign        Campaign      @relation(fields: [campaignId], references: [id])
  fileData        String        // Image encodée en base64 (stocké en DB)
  fileMimeType    String        // Ex: image/jpeg, image/png, application/pdf
  status          ReceiptStatus @default(PENDING)
  submittedAt     DateTime      @default(now())
  reviewedAt      DateTime?
  reviewedByEmail String?
}

// Un scan = un QR de campagne flashé, avant même le formulaire. Alimente le
// compteur de scans et le graphique 7/30 jours du dashboard.
model QrScanEvent {
  id         String   @id @default(cuid())
  campaignId String
  scannedAt  DateTime @default(now())

  @@index([campaignId, scannedAt])
}

// Code de vérification SMS envoyé avant de pouvoir jouer (Phase 8).
model OtpCode {
  id         String   @id @default(cuid())
  phone      String
  code       String
  campaignId String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([phone, campaignId])
}

// Historique des actions admin (création/édition/publication de campagne,
// changement de statut d'un gagnant, etc.) pour le back-office.
model ActivityLog {
  id         String   @id @default(cuid())
  userEmail  String
  partnerId  String? // Renseigné pour les actions faites par/sur un compte PARTNER ; null = action SUPERADMIN globale
  action     String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([partnerId])
}

// Espace client final (voyageurs) — auth et modèle entièrement séparés de
// User/Role (SUPERADMIN/PARTNER/READONLY). Un Customer n'est jamais un
// compte admin et ne doit jamais pouvoir passer superAdminProcedure/
// partnerProcedure. Lié en option à un User (PLAYER) pour réutiliser le
// système de jeu existant (campagnes/lots/participations) sans le dupliquer.
model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id])

  // Fidélité « Points Merci » (Phase 1). Le solde `points` est un CACHE : la
  // source de vérité est la somme des PointTransaction. `partnerId` = partenaire
  // d'origine du client (obooking par défaut) pour diviser les joueurs par
  // partenaire.
  points     Int      @default(0)
  partnerId  String?
  partner    Partner? @relation(fields: [partnerId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passwordResetTokens CustomerPasswordReset[]
  purchases           LoyaltyPurchase[]
  pointTxns           PointTransaction[]
  vouchers            LoyaltyVoucher[]

  @@index([partnerId])
}

// Jetons de réinitialisation de mot de passe côté client — jamais stockés en
// clair (tokenHash uniquement), courte durée de vie, à usage unique.
model CustomerPasswordReset {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
}

// ============================================================================
// Programme de fidélité « Points Merci » (Phase 1) — voir PLAN_FIDELITE.md
// ============================================================================

// Achat effectué par un client sur obooking.tn, transmis par webhook. Un achat
// peut arriver AVANT que le client ne crée son compte (status PENDING) : il est
// alors rattaché par email et crédité à la création du compte.
model LoyaltyPurchase {
  id           String    @id @default(cuid())
  orderRef     String    @unique         // Réf. commande obooking.tn → idempotence
  email        String                     // Email fourni par obooking.tn (rattachement)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  amountTnd    Float                      // Montant payé (TND)
  pointsEarned Int                        // Points calculés au moment de l'achat
  status       String    @default("PENDING") // PENDING / CREDITED
  description  String?
  purchasedAt  DateTime
  creditedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([email])
  @@index([customerId])
}

// Grand livre des points — SOURCE DE VÉRITÉ du solde. `delta` positif = gagné,
// négatif = utilisé. `balanceAfter` conserve le solde après opération (audit).
model PointTransaction {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  delta        Int
  type         String   // EARN_PURCHASE / REDEEM_VOUCHER / ADMIN_ADJUST
  reason       String?
  balanceAfter Int
  purchaseId   String?
  voucherId    String?
  createdAt    DateTime @default(now())

  @@index([customerId, createdAt])
}

// Bon de réduction TND généré quand un client convertit ses points. Usage unique.
model LoyaltyVoucher {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  code        String    @unique          // Code à utiliser sur obooking.tn
  pointsSpent Int
  valueTnd    Float                        // Valeur du bon (TND)
  status      String    @default("ACTIVE") // ACTIVE / REDEEMED / EXPIRED
  redeemedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([customerId])
}
