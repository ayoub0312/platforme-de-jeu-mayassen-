# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# base de données locale (contient des hashes de mot de passe et des emails
# de test réels issus des sessions de dev/QA — ne doit jamais être dans git)
dev.db
dev.db-journal
dev.db-wal
dev.db-shm
*.db
*.db-journal
*.db-wal
*.db-shm
prisma/dev.db*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# testsprite_tests/tmp/config.json contains a live API key — ignore the whole
# tmp/ directory (Windows backslashes above didn't actually match as a path
# separator, so this had been silently unignored).
testsprite_tests/tmp/

# Turso embedded replica (local, synced from remote)
.turso-replica.db
.turso-replica.db-*

# Backup ponctuel avant migration fidelite (peut etre supprime une fois valide)
backup_before_loyalty.json

# Fichiers locaux hors application
.claude/
*.docx
*.mp4
/obooking.png
*.mjs.tmp
